{
  "name": "devicon-kit-monorepo",
  "private": true,
  "scripts": {
    "icons:validate": "tsx scripts/validate-icons.ts",
    "icons:optimize": "tsx scripts/optimize-svgs.ts",
    "icons:generate": "tsx scripts/generate-components.ts && tsx scripts/generate-barrel.ts && tsx scripts/generate-dynamic-map.ts && tsx scripts/generate-metadata.ts",
    "icons:generate-frameworks": "tsx scripts/generate-frameworks.ts",
    "icons:build": "pnpm icons:validate && pnpm icons:optimize && pnpm icons:generate && pnpm icons:generate-frameworks",
    "build:lib": "pnpm icons:build && pnpm --filter devicon-kit build",
    "build:docs": "pnpm --filter docs build",
    "build": "turbo run build",
    "dev:docs": "pnpm --filter docs dev",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.12.0",
    "svgo": "^4.0.1",
    "svgson": "^5.3.1",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
